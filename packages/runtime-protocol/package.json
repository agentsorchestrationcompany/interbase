{
  "name": "@interbase/runtime-protocol",
  "version": "0.1.0",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/agentsorchestrationcompany/interbase"
  },
  "homepage": "https://github.com/agentsorchestrationcompany/interbase",
  "bugs": {
    "url": "https://github.com/agentsorchestrationcompany/interbase/issues"
  },
  "files": [
    "dist",
    "schema",
    "src"
  ],
  "exports": {
    ".": {
      "development": "./src/index.ts",
      "bun": "./src/index.ts",
      "types": "./src/index.ts",
      "import": "./dist/index.js"
    },
    "./schema/runtime-websocket.schema.json": "./schema/runtime-websocket.schema.json",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\" && tsc -p tsconfig.build.json",
    "coverage": "npm run build && NODE_OPTIONS='--conditions=development' vitest run --config vitest.config.ts --coverage --coverage.include=src/goal.ts --coverage.include=src/provider.ts --coverage.include=src/websocket.ts --coverage.thresholds.100 --coverage.thresholds.perFile",
    "test": "NODE_OPTIONS='--conditions=development' vitest run --config vitest.config.ts",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^24.5.2",
    "@vitest/coverage-v8": "^4.1.4",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "vitest": "^4.1.4"
  }
}
