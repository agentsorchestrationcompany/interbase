    "@interbase/runtime-protocol": "workspace:*",
    "@openai/codex-sdk": "^0.130.0"
  },
  "devDependencies": {
    "@types/bun": "1.3.12",
    "@types/node": "^24.5.2",
    "typescript": "^5.9.2"
  }
}
