{
  "name": "@interbase/cli-agent-backends",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "main": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./package.json": "./package.json"
  },
  "scripts": {
    "smoke:claude-live": "bun run scripts/claude-live-smoke.ts",
