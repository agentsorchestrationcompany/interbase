{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "paths": {
      "@interbase/plugin": ["../plugin/src/index.ts"],
      "@interbase/plugin/tui": ["../plugin/src/tui.ts"]
    },
    "strict": true,
    "typeRoots": ["./node_modules/@types", "../../node_modules/@types"],
    "types": ["bun", "node"],
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "noEmit": true
  },
  "include": ["src/**/*.ts", "test/**/*.test.ts"]
}
