{
  "name": "@interbase/cli-computer-use-plugin",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "main": "./src/index.ts",
  "files": [
    "src"
  ],
  "exports": {
    ".": "./src/index.ts",
    "./host": "./src/host.ts",
    "./schemas": "./src/schemas.ts",
    "./package.json": "./package.json"
  },
  "scripts": {
    "coverage": "NODE_OPTIONS='--conditions=development' vitest run --config ../../vitest.config.ts --project cli-computer-use-plugin --coverage --coverage.include=src/index.ts --coverage.include=src/host.ts --coverage.include=src/schemas.ts --coverage.thresholds.100 --coverage.thresholds.perFile",
    "test": "NODE_OPTIONS='--conditions=development' vitest run --config ../../vitest.config.ts --project cli-computer-use-plugin",
    "typecheck": "tsc --noEmit",
    "build": "tsc -p tsconfig.build.json"
  },
  "dependencies": {
    "@interbase/computer-use-policy": "workspace:*",
    "@interbase/computer-use-protocol": "workspace:*",
    "@interbase/plugin": "workspace:*",
    "effect": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "typescript": "catalog:",
    "vitest": "^4.1.4"
  }
}
