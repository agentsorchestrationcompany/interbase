{
  "name": "@interbase/computer-use-testkit",
  "version": "0.1.0",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/agentsorchestrationcompany/interbase"
  },
  "homepage": "https://github.com/agentsorchestrationcompany/interbase",
  "bugs": {
    "url": "https://github.com/agentsorchestrationcompany/interbase/issues"
  },
  "files": ["dist", "src"],
  "exports": {
    ".": {
      "development": "./src/index.ts",
      "bun": "./src/index.ts",
      "types": "./src/index.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\" && tsc -p tsconfig.build.json",
    "coverage": "bun test test/*.test.ts --coverage --coverage-reporter=lcov && bun run test/check-coverage.ts",
    "test": "bun test test/*.test.ts --coverage --coverage-reporter=lcov && bun run test/check-coverage.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@interbase/computer-use-protocol": "workspace:*",
    "@interbase/computer-use-policy": "workspace:*"
  },
  "devDependencies": {
    "@types/bun": "1.3.12",
    "@types/node": "^24.5.2",
    "typescript": "^5.9.2"
  }
}
